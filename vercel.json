{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/suporte",
      "destination": "/suporte.html"
    },
    {
      "source": "/((?!assets/|styles.css|app.js|pricing.js|suporte.js|supabase-config.js|login.html|suporte.html|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
